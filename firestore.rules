rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { 
      return request.resource.data; 
    }
    
    function existing() { 
      return resource.data; 
    }
    
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    function currentUserEmail() {
      return request.auth.token.email.lower();
    }
    
    function isGlobalAdmin() {
      return isSignedIn() && currentUserEmail() == "pegel03@gmail.com";
    }

    // 1. Teams collection rules
    match /teams/{teamId} {
      allow get: if true; // Publicly get the team name for shared URL / invites
      allow list: if isSignedIn() && (
        isGlobalAdmin() || 
        currentUserEmail() in resource.data.memberEmails || 
        currentUserEmail() in resource.data.teamAdminEmails
      );
      
      allow create: if isSignedIn() && isGlobalAdmin() && isValidTeam(incoming());
      
      allow update: if isSignedIn() && (
        (isGlobalAdmin() && isValidTeam(incoming())) ||
        (currentUserEmail() in existing().teamAdminEmails && isValidTeam(incoming()) && (
          incoming().id == existing().id
        ))
      );
      
      allow delete: if isSignedIn() && isGlobalAdmin();
    }

    function isValidTeam(team) {
      return team.id is string && team.id.size() <= 128
        && team.name is string && team.name.size() <= 128
        && team.memberEmails is list
        && team.teamAdminEmails is list
        && team.dashboardActive is bool;
    }

    // 2. Submissions collection rules
    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (
        isGlobalAdmin() ||
        resource.data.userEmail.lower() == currentUserEmail() ||
        currentUserEmail() in resource.data.allowedViewerEmails
      );
      
      allow list: if isSignedIn() && (
        isGlobalAdmin() ||
        resource.data.userEmail.lower() == currentUserEmail() ||
        currentUserEmail() in resource.data.allowedViewerEmails
      );
      
      allow create: if isSignedIn() 
        && isValidSubmission(incoming()) 
        && incoming().userEmail.lower() == currentUserEmail()
        && exists(/databases/$(database)/documents/teams/$(incoming().teamId));
        
      allow update: if false; // Submissions are immutable
      allow delete: if isSignedIn() && isGlobalAdmin();
    }

    function isValidSubmission(sub) {
      return sub.id is string && sub.id.size() <= 128
        && sub.teamId is string && sub.teamId.size() <= 128
        && sub.userEmail is string && sub.userEmail.size() <= 256
        && sub.scores is map
        && sub.submittedAt is string && sub.submittedAt.size() <= 64
        && sub.isSkipped is bool
        && sub.allowedViewerEmails is list;
    }
  }
}
