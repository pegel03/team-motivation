{
  "entities": {
    "Team": {
      "title": "Team",
      "description": "A team of members and its administrators",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the team" },
        "name": { "type": "string", "description": "The friendly name of the team" },
        "memberEmails": { "type": "array", "description": "Lid e-mailadressen" },
        "teamAdminEmails": { "type": "array", "description": "Designated team administrators" },
        "dashboardActive": { "type": "boolean", "description": "Whether the dashboard is open for members" }
      },
      "required": ["id", "name", "memberEmails", "teamAdminEmails", "dashboardActive"]
    },
    "Submission": {
      "title": "Submission",
      "description": "A survey response containing scores and user details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the submission" },
        "teamId": { "type": "string", "description": "The associated team ID" },
        "userEmail": { "type": "string", "description": "Email check for submission owner" },
        "scores": { "type": "object", "description": "Question IDs with their score" },
        "submittedAt": { "type": "string", "description": "ISO format string timestamp" },
        "isSkipped": { "type": "boolean", "description": "Whether to exclude this submission from score averages" }
      },
      "required": ["id", "teamId", "userEmail", "scores", "submittedAt", "isSkipped"]
    }
  },
  "firestore": {
    "teams/{teamId}": {
      "schema": "Team",
      "description": "The teams that users can submit surveys to"
    },
    "submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Surveys submitted by team members"
    }
  }
}
